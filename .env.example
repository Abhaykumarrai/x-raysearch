VITE_OPENAI_API_KEY=
# Optional override (default: gpt-4o)
# VITE_OPENAI_MODEL=gpt-4o-mini
VITE_SERP_API_KEY=
# LinkedIn X-Ray: Google SERP pages = SerpApi calls (default 3 pages = 3 calls, parallel). Max 10.
# VITE_SERP_MAX_PAGES=3
# Results per page (default 10). Each page is one Serp request.
# VITE_SERP_NUM=10
VITE_APOLLO_API_KEY=
# Optional: override Apollo async phone webhook. If unset, the app uses https://<current-origin>/api/apollo-webhook (good for Vercel previews).
# VITE_APOLLO_WEBHOOK_URL=https://YOUR_PROJECT.vercel.app/api/apollo-webhook
