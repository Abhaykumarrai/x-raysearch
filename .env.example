VITE_OPENAI_API_KEY=
# Optional override (default: gpt-4o)
# VITE_OPENAI_MODEL=gpt-4o-mini
VITE_SERP_API_KEY=
# LinkedIn X-Ray: Google SERP pages = SerpApi calls (default 3 pages = 3 calls, parallel). Max 10.
# VITE_SERP_MAX_PAGES=3
# Results per page (default 10). Each page is one Serp request.
# VITE_SERP_NUM=10
VITE_APOLLO_API_KEY=
# Optional: HTTPS URL Apollo can POST to when requesting phone reveal (e.g. ngrok). If unset, phone reveal is skipped so match still works.
# VITE_APOLLO_WEBHOOK_URL=https://your-server.example.com/apollo-webhook
